digraph FiniteAutomaton {
    rankdir=LR;
    node [shape=circle];
    node [shape=doublecircle]; "{q0,q1,q2,q3}" "{q0,q1,q2}" "{q2}";
    node [shape=circle];
    start [shape=point];
    start -> "{q0}";
    "{q0,q1,q2,q3}" -> "{q0,q1,q2,q3}" [label="a"];
    "{q0,q1,q2,q3}" -> "{q1}" [label="b"];
    "{q0,q1,q2}" -> "{q0,q1,q2,q3}" [label="a"];
    "{q0,q1,q2}" -> "{q1}" [label="b"];
    "{q0,q1}" -> "{q0,q1,q2}" [label="a"];
    "{q0,q1}" -> "{q1}" [label="b"];
    "{q0}" -> "{q0,q1}" [label="a"];
    "{q1}" -> "{q1}" [label="b"];
    "{q1}" -> "{q2}" [label="a"];
    "{q2}" -> "{q3}" [label="a"];
    "{q3}" -> "{q1}" [label="a"];
}
